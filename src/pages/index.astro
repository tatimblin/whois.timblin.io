---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import CarouselItem from "../components/CarouselItem.astro";
import "@whois/sticky-heading/styles.css";
import "@whois/wobble-text/styles.css";
import "@whois/gallery-carousel/styles.css";

const galleryItems = (await getCollection("gallery")).sort(
	(a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<script>
	import "@whois/sticky-heading";
	import "@whois/wobble-text";
	import "@whois/gallery-carousel";
</script>

<Layout>
	<main class="container">
		<sticky-heading class="page-title page-title--root"
			><h1>Tristan Timblin</h1></sticky-heading
		>

		<gallery-carousel>
			<div data-carousel-track>
				{galleryItems.map((item) => (
					<CarouselItem
						slug={item.id}
						media={item.data.media}
						type={item.data.type}
						poster={item.data.poster}
						alt={item.data.alt}
					/>
				))}
				<div data-carousel-cta>
					<a href="/gallery" class="carousel-cta">View all &rarr;</a>
				</div>
			</div>
		</gallery-carousel>

		<Section
			variant={1}
			revealRange="entry 50% exit 25%"
			expand
		>
			<sticky-heading slot="heading" class="page-title" reveal duration="600px"
				><wobble-text scale="3" speed="0.6" frequency="0.04"><h2>Tristan Timblin</h2></wobble-text></sticky-heading
			>
			<wobble-text scale="3" speed="0.6" frequency="0.04">
				<p>
					Body text for the first section. Replace this with a short paragraph
					describing what lives here — an intro, a project, or a thought.
				</p>
			</wobble-text>
		</Section>
		<Section
			variant={2}
			revealRange="entry 50% exit 25%"
		>
			<sticky-heading slot="heading" class="page-title" reveal duration="0"
				><h2>Section two</h2></sticky-heading
			>
			<p>
				Body text for the second section. A second beat to the page — could be
				selected work, writing, or anything that benefits from its own block.
			</p>
		</Section>
		<Section
			variant={3}
			revealRange="entry 50% exit 25%"
		>
			<sticky-heading slot="heading" class="page-title" reveal duration="0"
				><h2>Section three</h2></sticky-heading
			>
			<p>
				Body text for the third section. The last band — good place for contact
				info, a closing note, or a call to action.
			</p>
		</Section>

		<div class="scroll-spacer" aria-hidden="true"></div>
	</main>
</Layout>

<style is:global>
	:root {
		--sticky-heading-top: 20vh;
	}
</style>

<style>
	.page-title {
		display: block;
		padding-inline: var(--container-pad);
		color: var(--section-fg, var(--color-fg));
	}

	.page-title--root {
		margin-block: 50vh var(--space-6);
		color: var(--color-fg);
	}

	.page-title :global(h1),
	.page-title :global(h2) {
		font-size: var(--font-size-3xl);
		line-height: var(--line-height-tight);
		letter-spacing: -0.02em;
		font-weight: 700;
		color: inherit;
	}

	.scroll-spacer {
		height: 100vh;
	}

	.carousel-cta {
		display: inline-block;
		padding: var(--space-3) var(--space-5);
		color: var(--color-fg);
		text-decoration: none;
		font-weight: 600;
		font-size: var(--font-size-lg);
		white-space: nowrap;
	}

	.carousel-cta:hover {
		color: var(--color-muted);
	}
</style>
