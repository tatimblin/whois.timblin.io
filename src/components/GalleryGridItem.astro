---
interface Props {
	slug: string;
	title: string;
	media: string;
	type: "image" | "video";
	poster?: string;
	alt: string;
}

const { slug, title, media, type, poster, alt } = Astro.props;
---

<a href={`/gallery/${slug}`} class="gallery-grid-item">
	{
		type === "video" ? (
			<video
				src={media}
				poster={poster}
				preload="none"
				muted
				aria-label={alt}
				transition:name={`gallery-${slug}`}
			/>
		) : (
			<img
				src={media}
				alt={alt}
				loading="lazy"
				transition:name={`gallery-${slug}`}
			/>
		)
	}
	<span class="gallery-grid-item__title">{title}</span>
</a>

<style>
	.gallery-grid-item {
		display: block;
		break-inside: avoid;
		margin-bottom: var(--grid-gap, 1.5rem);
		border-radius: var(--radius);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		position: relative;
	}

	.gallery-grid-item img,
	.gallery-grid-item video {
		display: block;
		width: 100%;
		height: auto;
	}

	.gallery-grid-item__title {
		display: block;
		padding: var(--space-2) var(--space-3);
		font-size: var(--font-size-base);
		color: var(--color-muted);
	}
</style>
