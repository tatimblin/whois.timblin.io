---
interface Props {
	variant: 1 | 2 | 3;
	revealRange?: string;
	shrink?: boolean;
}

const { variant, revealRange, shrink } = Astro.props;
const revealId = revealRange
	? `section-reveal-${Math.random().toString(36).slice(2, 10)}`
	: undefined;

const animationName = shrink ? "section-bleed-reversible" : "section-bleed";
const css = revealId
	? `.${revealId} .section__canvas { animation: ${animationName} linear both; animation-timeline: view(); animation-range: ${revealRange}; }`
	: undefined;
---

{revealId && <style is:global set:html={css} />}

<section
	class:list={[
		"section",
		`section--${variant}`,
		{ "section--reveal": revealId },
		revealId,
	]}
>
	<div class="section__canvas">
		<slot name="canvas" />
	</div>
	<slot name="heading" />
	<div class="section__content grid">
		<div class="col-span-12">
			<slot />
		</div>
	</div>
</section>

<style>
	.section {
		position: relative;
		margin-block-end: calc(var(--space-7) * 2);
		color: var(--section-fg);
	}

	.section__canvas {
		position: absolute;
		inset: 0;
		width: 100vw;
		left: 50%;
		transform: translateX(-50%);
		background: var(--section-bg);
		overflow: hidden;
		clip-path: inset(
			0 max(var(--container-pad), calc(50vw - var(--container-max) / 2)) round
				var(--radius)
		);
	}

	.section__canvas > :global(*) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.section__content {
		position: relative;
		z-index: 1;
		max-width: var(--container-max);
		margin-inline: auto;
		padding-block: clamp(var(--space-7), 18vh, 12rem);
		padding-inline: var(--container-pad);
		min-height: 80vh;
	}

	.section:has(> sticky-heading[duration]) > .section__content {
		padding-block-start: 0;
	}

	.section :global(h2 + p) {
		margin-block-start: var(--space-3);
	}

	.section :global(p) {
		max-width: 65ch;
	}

	.section--1 {
		--section-bg: var(--section-1-bg);
		--section-fg: var(--section-1-fg);
	}
	.section--2 {
		--section-bg: var(--section-2-bg);
		--section-fg: var(--section-2-fg);
	}
	.section--3 {
		--section-bg: var(--section-3-bg);
		--section-fg: var(--section-3-fg);
	}

	@keyframes section-bleed {
		0% {
			clip-path: inset(
				0 max(var(--container-pad), calc(50vw - var(--container-max) / 2))
					round var(--radius)
			);
		}
		100% {
			clip-path: inset(0 0 round 0);
		}
	}

	@keyframes section-bleed-reversible {
		0%,
		100% {
			clip-path: inset(
				0 max(var(--container-pad), calc(50vw - var(--container-max) / 2))
					round var(--radius)
			);
		}
		50% {
			clip-path: inset(0 0 round 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.section .section__canvas {
			animation: none;
		}
	}
</style>
